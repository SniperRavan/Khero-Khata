# ============================================================
# Khero-Khata — .gitignore
# Pure HTML/CSS/JS project — No build tools or package managers
# ============================================================

# ──────────────────────────────────────────
# OS-Generated Files
# ──────────────────────────────────────────

# Windows
desktop.ini
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# ──────────────────────────────────────────
# Editor & IDE Files
# ──────────────────────────────────────────

# VS Code
.vscode/
*.code-workspace

# JetBrains (WebStorm, IDEA)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*.un~
Session.vim

# Emacs
*~
\#*\#
.\#*

# ──────────────────────────────────────────
# Node.js (if tooling is ever added)
# ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm

# ──────────────────────────────────────────
# Build & Distribution Artifacts
# ──────────────────────────────────────────
dist/
build/
out/
.cache/
.parcel-cache/

# ──────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json

# ──────────────────────────────────────────
# Logs & Temporary Files
# ──────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.orig

# ──────────────────────────────────────────
# Assets — Ignore large raw/source files
# (keep optimized production assets)
# ──────────────────────────────────────────
assets/raw/
assets/sources/
*.psd
*.ai
*.fig
*.sketch
*.xd

# ──────────────────────────────────────────
# Misc
# ──────────────────────────────────────────
*.zip
*.tar.gz
*.rar
TODO.local.md
NOTES.local.md
